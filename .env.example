# Copy this file to .env and fill in your real values.
# Nothing secret should ever be committed to git (.env is gitignored).
#   cp .env.example .env

# ---- Profile ----
YOUR_NAME=Your Name
YOUR_EMAIL=you@example.com
YOUR_PHONE=+91-0000000000

# ---- Gmail (for cold mail + reading job-alert emails over IMAP) ----
# Use a Gmail App Password (16 chars), NOT your normal password.
# Enable 2-Step Verification first, then create one at:
# https://myaccount.google.com/apppasswords
GMAIL_EMAIL=you@example.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ---- Telegram ----
# Create a bot via @BotFather (/newbot) to get the token.
# Get your numeric chat id from @userinfobot. The bot only replies to this id.
TELEGRAM_BOT_TOKEN=000000000:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=000000000

# ---- Behaviour toggles ----
# When DRY_RUN=true no emails are actually sent (drafts are written to disk instead).
DRY_RUN=true
# Require manual confirmation before any cold mail leaves your account.
REQUIRE_MAIL_CONFIRM=true

# ---- LLM match scoring (optional, via Groq — free tier) ----
# When on, jobs are scored by an LLM for how well your resume matches the role
# (a "Match" score, not a hiring probability). Falls back to the keyword scorer
# if the key is missing or a call fails, so it never breaks a run.
# Get a free key at https://console.groq.com/keys  (OpenAI-compatible API).
USE_LLM_SCORING=true
GROQ_API_KEY=

# Optional overrides:
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# ---- Google walk-in drive search (optional, free 100 queries/day) ----
# Powers the walkin_search source, which hunts Google for walk-in interview
# drives and records date/time/venue. Two free steps (leave blank to keep off):
#  1) Create a Programmable Search Engine (search the WHOLE web) at
#     https://programmablesearchengine.google.com  -> copy the "Search engine ID" (cx)
#  2) In https://console.cloud.google.com enable "Custom Search API" -> create an
#     API key. Free tier = 100 queries/day (this source uses ~32/day).
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ---- Scraping-API proxy (to scrape Naukri, which is behind Akamai anti-bot) ----
# Naukri blocks direct scraping (even headless browsers). A scraping-API proxy
# solves the anti-bot + uses residential IPs and returns the rendered page.
# Sign up for a free trial (~1000 calls/mo) and paste the key below:
#   ScraperAPI:  https://www.scraperapi.com   (default; works as-is)
#   ZenRows / ScrapingBee also work — set SCRAPER_API_URL to their endpoint.
# Leave blank to keep the Naukri proxy path off (it'll try the direct path).
SCRAPER_API_KEY=
# SCRAPER_API_URL=https://api.scraperapi.com/   # override for ZenRows/ScrapingBee
# SCRAPER_COUNTRY=in                            # residential IP country
# SCRAPER_RENDER=true                           # run JS (needed to beat Akamai)

# ---- Daily auto-fetch (dashboard) ----
# AUTO_FETCH=1 runs the pipeline daily while the dashboard is open.
# AUTO_FETCH_TIMES=08:00,18:00   # one or more HH:MM
# GMAIL_LOOKBACK_HOURS=26        # inbox history per run (daily run needs ~26h)
