# Copy this file to .env and fill in your real values.
# Nothing secret should ever be committed to git (.env is gitignored).
#   cp .env.example .env

# ---- Profile ----
YOUR_NAME=Your Name
YOUR_EMAIL=you@example.com
YOUR_PHONE=+91-0000000000

# ---- Gmail (for cold mail + reading job-alert emails over IMAP) ----
# Use a Gmail App Password (16 chars), NOT your normal password.
# Enable 2-Step Verification first, then create one at:
# https://myaccount.google.com/apppasswords
GMAIL_EMAIL=you@example.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ---- Telegram ----
# Create a bot via @BotFather (/newbot) to get the token.
# Get your numeric chat id from @userinfobot. The bot only replies to this id.
TELEGRAM_BOT_TOKEN=000000000:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=000000000

# ---- Behaviour toggles ----
# When DRY_RUN=true no emails are actually sent (drafts are written to disk instead).
DRY_RUN=true
# Require manual confirmation before any cold mail leaves your account.
REQUIRE_MAIL_CONFIRM=true
